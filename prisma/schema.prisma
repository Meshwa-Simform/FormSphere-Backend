// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid()) @db.Uuid
  name     String
  email    String @unique
  password String

  Form Form[]
}

model Form {
  id                  String     @id @default(uuid()) @db.Uuid
  userId              String     @db.Uuid
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title               String
  description         String
  logoUrl             String?
  isSinglePage        Boolean    @default(true)
  noOfPages           Int        @default(1)
  questions           Question[]
  styling             Json?
  privateSharingToken String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  ConditionalLogic ConditionalLogic[]
  Response         Response[]
}

model Templates {
  id                  String     @id @default(uuid()) @db.Uuid
  title               String
  description         String
  logoUrl             String?
  isSinglePage        Boolean    @default(true)
  noOfPages           Int        @default(1)
  questions           Question[]
  styling             Json
  privateSharingToken String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
}

model Question {
  id              String     @id @default(uuid()) @db.Uuid
  formId          String?    @db.Uuid
  form            Form?      @relation(fields: [formId], references: [id], onDelete: Cascade)
  templateId      String?    @db.Uuid
  template        Templates? @relation(fields: [templateId], references: [id], onDelete: Cascade)
  pageNumber      Int
  questionType    String
  questionText    String
  questionOptions String[]
  validations     String[]
  questionAnswer  String?
  questionOrder   Int
  isRequired      Boolean    @default(false)
  isHidden        Boolean    @default(false)

  ConditionalLogic ConditionalLogic[]
}

model ConditionalLogic {
  id                String   @id @default(uuid()) @db.Uuid
  formId            String   @db.Uuid
  form              Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  questionId        String   @db.Uuid
  question          Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  condition_check   String
  action_questionId String[]
}

model Response {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  userName  String
  userEmail String
  formId    String   @db.Uuid
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers   Answer[] @relation("ResponseToAnswer")
  createdAt DateTime @default(now())
}

model Answer {
  id              String   @id @default(uuid()) @db.Uuid
  responseId      String   @db.Uuid
  response        Response @relation("ResponseToAnswer", fields: [responseId], references: [id], onDelete: Cascade)
  questionId      String   @db.Uuid
  questionType    String
  questionText    String
  questionOptions String[]
  questionAnswer  String?
  questionOrder   Int
  responseAnswer  String
}
